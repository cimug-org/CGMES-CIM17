      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Negative sequence series resistance from terminal sequence  1 to terminal sequence 2. Used for short circuit data exchange according to IEC 60909.
EquivalentBranch is a result of network reduction prior to the data exchange.</rdfs:comment>
      <rdfs:domain rdf:resource="#EquivalentBranch"/>
      <rdfs:label xml:lang="en">negativeR12</rdfs:label>
   </rdf:Description>
