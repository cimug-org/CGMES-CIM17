      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angular acceleration, radians per second squared.</rdfs:comment>
      <rdfs:label xml:lang="en">radPers2</rdfs:label>
   </rdf:Description>
   <rdf:Description rdf:about="#UnitSymbol.rev">
      <cims:stereotype>enum</cims:stereotype>
