      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Time, Ratio of time.  Note: Users may need to supply a prefix such as �&amp;#181;� to show rates such as �&amp;#181;s/s�.</rdfs:comment>
      <rdfs:label xml:lang="en">sPers</rdfs:label>
   </rdf:Description>
   <rdf:Description rdf:about="#UnitSymbol.sr">
      <cims:stereotype>enum</cims:stereotype>
