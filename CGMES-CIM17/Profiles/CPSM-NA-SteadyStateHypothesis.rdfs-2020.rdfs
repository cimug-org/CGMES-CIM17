      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wavenumber, reciprocal metres,  (1/m).</rdfs:comment>
      <rdfs:label xml:lang="en">onePerm</rdfs:label>
   </rdf:Description>
   <rdf:Description rdf:about="#UnitSymbol.ppm">
      <cims:stereotype>enum</cims:stereotype>
