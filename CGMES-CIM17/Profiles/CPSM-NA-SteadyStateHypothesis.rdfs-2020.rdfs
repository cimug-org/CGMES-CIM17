      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concentration, The amount of substance concentration, (c), the amount of solvent in moles divided by the volume of solution in m�.</rdfs:comment>
      <rdfs:label xml:lang="en">molPerm3</rdfs:label>
   </rdf:Description>
   <rdf:Description rdf:about="#UnitSymbol.molPermol">
      <cims:stereotype>enum</cims:stereotype>
