   </rdf:Description>
   <rdf:Description rdf:about="#UnitSymbol.rotPers">
      <cims:stereotype>enum</cims:stereotype>
      <rdf:type rdf:resource="#UnitSymbol"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rotations per second (1/s). See also Hz (1/s).</rdfs:comment>
      <rdfs:label xml:lang="en">rotPers</rdfs:label>
   </rdf:Description>
