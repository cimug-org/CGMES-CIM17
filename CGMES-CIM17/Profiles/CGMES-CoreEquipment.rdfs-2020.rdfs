      <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The connectivity node to which this terminal connects with zero impedance.</rdfs:comment>
      <rdfs:domain rdf:resource="#Terminal"/>
      <rdfs:label xml:lang="en">ConnectivityNode</rdfs:label>
      <rdfs:range rdf:resource="#ConnectivityNode"/>
   </rdf:Description>
