      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The synchronous machine drives the turbine which moves the water from a low elevation to a higher elevation. The direction of machine rotation for pumping may or may not be the same as for generating.</rdfs:comment>
      <rdfs:domain rdf:resource="#HydroPump"/>
      <rdfs:label xml:lang="en">RotatingMachine</rdfs:label>
      <rdfs:range rdf:resource="#RotatingMachine"/>
   </rdf:Description>
