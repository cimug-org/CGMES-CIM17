      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The minimum direct current (Id) on the DC side at which the converter should operate. It is converter�s configuration data used in power flow. The attribute shall be a positive value.</rdfs:comment>
      <rdfs:domain rdf:resource="#CsConverter"/>
      <rdfs:label xml:lang="en">minIdc</rdfs:label>
   </rdf:Description>
