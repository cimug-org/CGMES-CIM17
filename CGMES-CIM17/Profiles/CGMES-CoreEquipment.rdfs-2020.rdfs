      <cims:stereotype>enum</cims:stereotype>
      <rdf:type rdf:resource="#WindingConnection"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autotransformer common winding.</rdfs:comment>
      <rdfs:label xml:lang="en">A</rdfs:label>
   </rdf:Description>
   <rdf:Description rdf:about="#WindingConnection.D">
      <cims:stereotype>enum</cims:stereotype>
      <rdf:type rdf:resource="#WindingConnection"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Delta.</rdfs:comment>
