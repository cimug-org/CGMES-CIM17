      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The hydro pump may be a member of a pumped storage plant or a pump for distributing water.</rdfs:comment>
      <rdfs:domain rdf:resource="#HydroPump"/>
      <rdfs:label xml:lang="en">HydroPowerPlant</rdfs:label>
      <rdfs:range rdf:resource="#HydroPowerPlant"/>
   </rdf:Description>
   <rdf:Description rdf:about="#HydroPump.RotatingMachine">
      <cims:AssociationUsed>Yes</cims:AssociationUsed>
