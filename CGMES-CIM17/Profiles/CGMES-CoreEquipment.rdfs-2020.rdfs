      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The conducting equipment of the terminal.  Conducting equipment have  terminals that may be connected to other conducting equipment terminals via connectivity nodes or topological nodes.</rdfs:comment>
      <rdfs:domain rdf:resource="#Terminal"/>
      <rdfs:label xml:lang="en">ConductingEquipment</rdfs:label>
      <rdfs:range rdf:resource="#ConductingEquipment"/>
   </rdf:Description>
   <rdf:Description rdf:about="#Terminal.ConnectivityNode">
      <cims:AssociationUsed>Yes</cims:AssociationUsed>
