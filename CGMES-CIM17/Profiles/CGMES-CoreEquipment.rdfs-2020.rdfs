      <rdfs:label xml:lang="en">WindPowerPlant</rdfs:label>
      <rdfs:range rdf:resource="http://iec.ch/TC57/CIM100-European#WindPowerPlant"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://iec.ch/TC57/CIM100-European#WindPowerPlant">
      <cims:belongsToCategory rdf:resource="#Package_ExtEuProduction"/>
      <cims:stereotype rdf:resource="http://iec.ch/TC57/NonStandard/UML#concrete"/>
