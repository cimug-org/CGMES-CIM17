      <cims:stereotype>European</cims:stereotype>
      <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A solar power plant may have solar generating units.</rdfs:comment>
      <rdfs:domain rdf:resource="#SolarGeneratingUnit"/>
      <rdfs:label xml:lang="en">SolarPowerPlant</rdfs:label>
      <rdfs:range rdf:resource="http://iec.ch/TC57/CIM100-European#SolarPowerPlant"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://iec.ch/TC57/CIM100-European#SolarPowerPlant">
      <cims:belongsToCategory rdf:resource="#Package_ExtEuProduction"/>
      <cims:stereotype rdf:resource="http://iec.ch/TC57/NonStandard/UML#concrete"/>
      <cims:stereotype>European</cims:stereotype>
      <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Solar power plant.</rdfs:comment>
      <rdfs:label xml:lang="en">SolarPowerPlant</rdfs:label>
      <rdfs:subClassOf rdf:resource="#PowerSystemResource"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://iec.ch/TC57/CIM100-European#SolarPowerPlant.SolarGeneratingUnits">
      <cims:AssociationUsed>No</cims:AssociationUsed>
      <cims:inverseRoleName rdf:resource="http://iec.ch/TC57/CIM100-European#SolarGeneratingUnit.SolarPowerPlant"/>
      <cims:multiplicity rdf:resource="http://iec.ch/TC57/1999/rdf-schema-extensions-19990926#M:0..n"/>
      <cims:stereotype>European</cims:stereotype>
      <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A solar generating unit or units may be a member of a solar power plant.</rdfs:comment>
      <rdfs:domain rdf:resource="http://iec.ch/TC57/CIM100-European#SolarPowerPlant"/>
      <rdfs:label xml:lang="en">SolarGeneratingUnits</rdfs:label>
      <rdfs:range rdf:resource="#SolarGeneratingUnit"/>
   </rdf:Description>
